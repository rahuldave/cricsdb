# Copy to .env and fill in real values. NEVER commit .env (it's gitignored).
#
# Loaded automatically at startup by api/app.py whether you launch via
# `uv run uvicorn api.app:app` or `uv run python main.py`.
#
# For plash: deploy.sh stages .env into build_plash/ so the credentials
# travel with the deploy. Gitignored at both ends.
#
# If .env is missing or these are blank, /admin/* returns 503 (fail-closed).

# HTTP Basic Auth for the deebase /admin/ UI.
ADMIN_USERNAME=
ADMIN_PASSWORD=
